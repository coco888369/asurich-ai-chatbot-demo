# ============================================================
# AI Chatbot Demo - Environment Variables Template
# ============================================================
# このファイルをコピーして `.env` を作成し、実際の値を設定してください。
# `.env` は .gitignore で除外されるため、Gitに含まれません。
#
# 本デモはベンダー非依存に設計されており、
# OpenAI互換APIエンドポイントを提供するLLMプロバイダであれば
# どれでも動作します（Groq, OpenAI, Anthropic via proxy など）。
# ============================================================

# LLM API Key（利用するLLMプロバイダのキー）
LLM_API_KEY=your_api_key_here

# 使用するモデル名（プロバイダに応じて設定）
LLM_MODEL=your-model-name

# APIエンドポイント（OpenAI互換の /chat/completions 形式）
LLM_ENDPOINT=https://api.example.com/v1/chat/completions
