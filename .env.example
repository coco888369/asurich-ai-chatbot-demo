# ============================================================
# Asurich AI Chatbot - Environment Variables Template
# ============================================================
# このファイルをコピーして `.env` を作成し、実際のAPIキーを設定してください。
# `.env` は .gitignore で除外されるため、Gitに含まれません。
#
# Groq APIキーの取得方法:
#   1. https://console.groq.com にアクセス
#   2. 無料アカウント作成
#   3. API Keys から新規キーを発行
# ============================================================

GROQ_API_KEY=your_groq_api_key_here
